  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "concurrently \"tsc --watch\" \"nodemon dist/index.js\"",
    "migrate": "knex migrate:latest --knexfile knexfile.cjs",
    "rollback": "knex migrate:rollback --all --knexfile knexfile.cjs",
    "seed": "knex seed:run --knexfile knexfile.cjs",
    "es:create": "tsx src/scripts/createIndex.ts",
    "es:sync": "tsx src/scripts/syncBooks.ts",
    "es:setup": "npm run es:create && npm run es:sync"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.19.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "knex": "^3.2.9",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
